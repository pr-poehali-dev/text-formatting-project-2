{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "POST without body returns 400",
      "method": "POST",
      "path": "/",
      "body": "{\"name\": \"\", \"phone\": \"\"}",
      "expectedStatus": 400
    },
    {
      "name": "GET not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}